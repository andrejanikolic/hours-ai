{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["@playwright/test", "node"],
    "noEmit": true
  },
  "include": ["**/*.ts", "**/*.json"]
}
